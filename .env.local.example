# Copy this to .env.local for local development.
#
# Leave VITE_R2_BASE_URL empty to serve dora.json + repo_summary*.csv from the
# local dev server (place the files in the project root).
VITE_R2_BASE_URL=

# In production this points at the Access-gated Pages Function (NOT a public R2
# URL). The function lives at functions/api/data/[file].ts and serves files from
# the PRIVATE R2 bucket only after verifying the Cloudflare Access JWT.
#
# Production value (set as the VITE_R2_BASE_URL repo secret):
# VITE_R2_BASE_URL=/api/data
