# Copy this to .env.local for local development
# Leave VITE_R2_BASE_URL empty to serve dora.json from local dev server (place it in project root)
VITE_R2_BASE_URL=

# Or point at R2 for dev (requires public bucket access + CORS):
# VITE_R2_BASE_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
